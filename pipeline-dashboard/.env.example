DATABASE_URL=sqlite+aiosqlite:///data/pipeline.db
PIPELINE_PROJECTS_DIR=projects
PIPELINE_DATA_DIR=data
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_CLI_PATH=claude
GEMINI_CLI_PATH=gemini
# Curated model lists for the CLI providers (comma-separated). The Claude and
# Gemini CLIs have no "list models" command, so these populate the dropdown and
# the selected value is passed via --model / -m at run time.
CLAUDE_MODELS=opus,sonnet,haiku,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5
GEMINI_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite
# Per-agent model tiering (speed). The model you select in the UI is the "strong" tier
# and is always used for the gate phases (architect, code review, QA). Mechanical phases
# (proj_manager, devops, tech_writer) use the fast model below when set. Leave empty to
# disable tiering entirely (every agent uses the selected model).
CLAUDE_FAST_MODEL=
GEMINI_FAST_MODEL=
GUARDRAILS_FILE=guardrails.json
ENV=dev
